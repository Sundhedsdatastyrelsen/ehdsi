##############################################################################
#  OpenNCP tomcat SSL connector properties                                   #
##############################################################################
CONNECTOR_PORT=${NCP_A_SERVER_CONNECTOR_PORT}
CONNECTOR_SECURE_PORT=${NCP_A_SERVER_CONNECTOR_SECURE_PORT}
KEY_ALIAS=${TLS_PROVIDER_KEY_ALIAS}
KEYSTORE_PATH=${TLS_PROVIDER_KEYSTORE_PATH}
TRUSTSTORE_PATH=${TLS_TRUSTSTORE_PATH}
TRUSTSTORE_PASSWORD=${TLS_TRUSTSTORE_PWD}
CLIENT_AUTH=true #true for connector A and false for connector B (officer node)

#########################################################################################
# These container environment properties are bound via the docker compose ".env" file.  #
# !!! DO NOT CHANGE THIS !!!                                                            #
#########################################################################################
DB_PORT=${DB_PORT}
DB_USER=${DB_USER}
DB_PWD_FILE=${DB_PWD_FILE}
DB_TYPE=${DB_TYPE}
DB_HOST=${DB_HOST}
DATASOURCE_CLASS_NAME=${DATASOURCE_CLASS_NAME}
DRIVER_CLASS_NAME=${DRIVER_CLASS_NAME}
